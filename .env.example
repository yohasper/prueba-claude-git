# ============================================================
# DATAWAREHOUSE PROJECT - Variables de Entorno
# Copia este archivo como .env y completa tus valores
# ¡NUNCA subas .env a Git!
# ============================================================

# --- PostgreSQL (Bodega de Datos Local) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datawarehouse
DB_USER=dw_user
DB_PASSWORD=tu_password_seguro
DB_SCHEMA_BRONZE=bronze

# --- Google Drive API ---
GOOGLE_CREDENTIALS_PATH=config/credentials/google_credentials.json
GOOGLE_TOKEN_PATH=config/credentials/token.json

# --- IDs de carpetas/archivos en Google Drive ---
# Puedes definir uno o varios IDs de carpetas con Excel
GDRIVE_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Control de Ingesta ---
BATCH_SIZE=1000
LOG_LEVEL=INFO
LOG_PATH=logs/

# --- Entorno ---
ENV=development
